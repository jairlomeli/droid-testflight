// firestore.rules
// Pega estas reglas en Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Plataformas — lectura pública, escritura solo admin
    match /platforms/{doc} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Versiones — lectura pública, escritura solo admin
    match /versions/{doc} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Builds — lectura pública, escritura solo admin
    match /builds/{doc} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Invites — lectura pública (para validar código), escritura solo admin
    match /invites/{inviteId} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.token.admin == true;

      // Subcolección de dispositivos — cualquiera puede leer y registrar
      // (el cliente verifica el límite de 4 antes de crear)
      match /devices/{deviceId} {
        allow read:   if true;
        allow create: if true;
      }
    }

    // Logs de acceso — admin puede leer, cualquiera puede crear
    match /accessLogs/{doc} {
      allow read:   if request.auth != null && request.auth.token.admin == true;
      allow create: if true;
    }

    // Logs de instalación — admin puede leer, cualquiera puede crear
    match /installLogs/{doc} {
      allow read:   if request.auth != null && request.auth.token.admin == true;
      allow create: if true;
    }
  }
}
